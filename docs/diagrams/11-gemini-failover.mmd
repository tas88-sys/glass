%% 11 - Gemini LLM failover (LLM ONLY — STT never fails over)
%% User supplies a comma-separated model priority list, e.g.
%%   gemini-3-pro, gemini-2.5-flash, gemini-2.5-flash-lite
%% On a transient error the current model is cooled down and the next is tried.
%% Source: gemini.js (callWithFailover / streamOneAttempt) + geminiModelRotator.js
flowchart TB
    start(["createStreamingLLM / createLLM with model CSV"]) --> parse["parseModelList(csv)<br/>trim, drop empties -> remaining[]"]
    parse --> pick["pickModel(remaining)<br/>first healthy in order;<br/>if all cooling, soonest-to-recover"]
    pick --> call["attempt model: streamOneAttempt() / doCall()"]
    call --> ok{"success?"}

    ok -->|yes| done["markSucceeded (clear cooldown)<br/>emit _final_model -> footer 'answered by: X'<br/>(append '(fallback)' if any _reset fired)"]
    done --> finish(["[DONE] / return"])

    ok -->|error| classify["classifyError(err)<br/>status -> errorDetails reason -> message text"]
    classify --> kind{"kind?"}

    kind -->|"fatal-auth (401/403, API_KEY_INVALID)"| fatal["controller.error() / throw<br/>surface immediately"]
    kind -->|"fatal-request (400, INVALID_ARGUMENT)"| fatal
    kind -->|"transient (408/429/5xx, network,<br/>RESOURCE_EXHAUSTED, UNAVAILABLE)"| cool["markFailed(model, parseRetryAfter(err))<br/>cooldown = Retry-After / retryDelay,<br/>default 60s, clamped [5s, 300s]"]

    cool --> reset["streaming: emit {_reset, next_model}<br/>-> consumer wipes partial output"]
    reset --> more{"remaining models left?"}
    more -->|yes| pick
    more -->|no| allfail["controller.error(lastErr) / throw lastErr"]

    note["Health registry = in-memory singleton Map (resets on restart).<br/>STT path calls parseModelList(csv)[0] only — NO failover by design<br/>(live session has no clean rotation semantics)."]
    parse -.-> note
